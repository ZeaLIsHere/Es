<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.taskforge.ui.controller.LoginController"
           prefWidth="480" prefHeight="660"
           style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #EEF2FF, #F1F5F9);">

    <VBox alignment="CENTER" spacing="0" maxWidth="400">

        <!-- Card -->
        <VBox styleClass="form-card" spacing="18"
              style="-fx-pref-width: 400;">

            <!-- Header accent bar -->
            <Region style="-fx-background-color: #4F46E5;
                           -fx-background-radius: 20 20 0 0;
                           -fx-min-height: 6; -fx-max-height: 6;"/>

            <VBox spacing="18" style="-fx-padding: 28 32 32 32;">

            <VBox spacing="10" alignment="CENTER" style="-fx-padding: 0 0 8 0;">
                <ImageView fitWidth="72" fitHeight="72" preserveRatio="true" smooth="true">
                    <image><Image url="@/images/taskforge-icon-128.png"/></image>
                </ImageView>
                <HBox alignment="CENTER" spacing="0">
                    <Label text="Task"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                    <Label text="Forge"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
                </HBox>
                <Label text="Project Hub untuk Mahasiswa"
                       style="-fx-font-size: 13px; -fx-text-fill: #94A3B8;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Selamat datang kembali"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                <Label text="Masuk untuk mengelola proyek kamu"
                       style="-fx-font-size: 13px; -fx-text-fill: #94A3B8;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Alamat Email" styleClass="field-label"/>
                <TextField fx:id="emailField"
                           promptText="nama@email.com"
                           styleClass="text-field"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="Masukkan password"
                               styleClass="text-field"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-label"
                   wrapText="true" visible="false"/>

            <VBox spacing="10" alignment="CENTER" style="-fx-padding: 4 0 0 0;">
                <Button fx:id="loginButton"
                        text="Masuk"
                        onAction="#handleLogin"
                        styleClass="primary-button"
                        maxWidth="Infinity"/>
                <ProgressIndicator fx:id="loadingIndicator"
                                   prefWidth="28" prefHeight="28"
                                   visible="false"/>
            </VBox>

            <HBox alignment="CENTER" spacing="4">
                <Label text="Belum punya akun?"
                       style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
                <Hyperlink text="Daftar sekarang"
                           onAction="#handleRegisterLink"
                           style="-fx-text-fill: #4F46E5; -fx-font-size: 13px;
                                  -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>
            </VBox>
        </VBox>
    </VBox>
</StackPane>

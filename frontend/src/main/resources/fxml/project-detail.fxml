<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.taskforge.ui.controller.ProjectDetailController"
            style="-fx-background-color: #F8FAFC;">

    <left>
        <VBox minWidth="220" prefWidth="220" maxWidth="220" spacing="0"
              style="-fx-background-color: #0F172A;">

            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 16 16 16 16;
                         -fx-border-color: #1E293B; -fx-border-width: 0 0 1 0;">
                <ImageView fitWidth="34" fitHeight="34" preserveRatio="true" smooth="true">
                    <image><Image url="@/images/taskforge-icon-48.png"/></image>
                </ImageView>
                <HBox spacing="0" alignment="CENTER_LEFT">
                    <Label text="Task"
                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Forge"
                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #6366F1;"/>
                </HBox>
            </HBox>

            <VBox spacing="6"
                  style="-fx-padding: 16 16 16 16;
                         -fx-border-color: #1E293B; -fx-border-width: 0 0 1 0;">
                <StackPane prefWidth="56" prefHeight="56">
                    <Rectangle width="56" height="56" arcWidth="12" arcHeight="12"
                               style="-fx-fill: #0F172A;"/>
                    <Label fx:id="avatarInitials" text="?"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"
                           StackPane.alignment="CENTER"/>
                </StackPane>

                <Label text="AKUN SAYA"
                       style="-fx-font-size: 9px; -fx-font-weight: bold;
                              -fx-text-fill: #475569; -fx-padding: 6 0 0 0;"/>
                <Label fx:id="userNameLabel"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;
                              -fx-text-fill: #F1F5F9; -fx-wrap-text: true;"
                       maxWidth="188"/>
                <Label fx:id="userNimLabel" text=""
                       style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>

                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="userRoleLabel"
                           style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #A5B4FC;
                                  -fx-background-color: #1E1B4B; -fx-background-radius: 20;
                                  -fx-padding: 3 10 3 10;"/>
                </HBox>
            </VBox>

            <VBox spacing="0">
                <Label text="WORKSPACE"
                       style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #475569;
                              -fx-padding: 16 0 6 20;"/>
                <Button text="  Dashboard" onAction="#handleDashboard"
                        styleClass="sidebar-nav-btn"
                        style="-fx-max-width: Infinity; -fx-pref-width: 220;"/>
                <Button text="  Proyek" onAction="#handleProyek"
                        styleClass="sidebar-nav-btn-active"
                        style="-fx-max-width: Infinity; -fx-pref-width: 220;"/>
                <Button text="  Notifikasi" onAction="#handleNotifikasi"
                        styleClass="sidebar-nav-btn"
                        style="-fx-max-width: Infinity; -fx-pref-width: 220;"/>
                <Button text="  Profil" onAction="#handleProfil"
                        styleClass="sidebar-nav-btn"
                        style="-fx-max-width: Infinity; -fx-pref-width: 220;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox style="-fx-border-color: #1E293B; -fx-border-width: 1 0 0 0;">
                <Button text="  Keluar" onAction="#handleLogout"
                        styleClass="sidebar-logout-btn"
                        style="-fx-max-width: Infinity; -fx-pref-width: 220;"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="0" style="-fx-background-color: #F8FAFC;">
            <ScrollPane fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox spacing="20" style="-fx-padding: 24 28 28 28;">

                    <Button text="← Kembali ke Proyek" onAction="#handleBack"
                            style="-fx-background-color: transparent; -fx-text-fill: #64748B;
                                   -fx-font-size: 13px; -fx-padding: 0; -fx-cursor: hand;"/>

                    <ProgressIndicator fx:id="loadingIndicator"
                                       prefWidth="36" prefHeight="36" visible="false"/>
                    <Label fx:id="statusLabel"
                           style="-fx-text-fill: #EF4444; -fx-font-size: 13px;"/>

                    <!-- Project Info Card -->
                    <VBox spacing="16"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-border-width: 1;
                                 -fx-padding: 24 28 24 28;
                                 -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.05), 8, 0, 0, 2);">

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label fx:id="projectTitleLabel" text="Proyek"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                                <Label fx:id="projectDescLabel" text=""
                                       wrapText="true"
                                       style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
                            </VBox>
                            <Label text="ACTIVE"
                                   style="-fx-background-color: #10B981; -fx-text-fill: white;
                                          -fx-font-size: 10px; -fx-font-weight: bold;
                                          -fx-background-radius: 20; -fx-padding: 4 12 4 12;"/>
                        </HBox>

                        <HBox spacing="32" alignment="CENTER_LEFT">
                            <VBox spacing="4">
                                <Label text="KETUA"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #94A3B8;"/>
                                <Label fx:id="ketuaLabel" text="-"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="PERIODE"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #94A3B8;"/>
                                <Label fx:id="periodeLabel" text="-"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="ANGGOTA"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #94A3B8;"/>
                                <Label fx:id="anggotaCountLabel" text="-"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Button fx:id="kanbanButton" text="Kanban Board" onAction="#handleKanban"
                                    style="-fx-background-color: #0F172A; -fx-text-fill: white;
                                           -fx-font-size: 13px; -fx-font-weight: bold;
                                           -fx-background-radius: 10; -fx-padding: 10 20 10 20;
                                           -fx-cursor: hand;"/>
                            <Button fx:id="reportButton" text="Heatmap" onAction="#handleReport"
                                    style="-fx-background-color: white; -fx-text-fill: #0F172A;
                                           -fx-font-size: 13px; -fx-font-weight: bold;
                                           -fx-background-radius: 10; -fx-padding: 10 20 10 20;
                                           -fx-border-color: #E2E8F0; -fx-border-radius: 10;
                                           -fx-border-width: 1; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <!-- Team Members Card -->
                    <VBox spacing="16"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-border-width: 1;
                                 -fx-padding: 24 28 24 28;
                                 -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.05), 8, 0, 0, 2);">

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="ANGGOTA TIM"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="addMemberButton" text="+ Tambah" onAction="#handleAddMember"
                                    style="-fx-background-color: #0F172A; -fx-text-fill: white;
                                           -fx-font-size: 12px; -fx-font-weight: bold;
                                           -fx-background-radius: 8; -fx-padding: 7 14 7 14;
                                           -fx-cursor: hand;"/>
                        </HBox>

                        <VBox fx:id="membersPane" spacing="10"/>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>

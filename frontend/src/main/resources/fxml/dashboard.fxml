<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.taskforge.ui.controller.DashboardController"
            style="-fx-background-color: #F1F5F9;">

    <!-- Left Sidebar -->
    <left>
        <VBox minWidth="210" prefWidth="210" maxWidth="210" spacing="0"
              style="-fx-background-color: #1E3A8A;">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-padding: 16 16 12 16; -fx-border-color: #2563EB; -fx-border-width: 0 0 1 0;">
                <Label text="TaskForge"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </HBox>

            <!-- User info with photo -->
            <VBox spacing="6"
                  style="-fx-padding: 14 16 14 16; -fx-border-color: #2563EB; -fx-border-width: 0 0 1 0;">

                <!-- Avatar circle or photo -->
                <StackPane alignment="CENTER" prefWidth="56" prefHeight="56">
                    <!-- Default avatar (colored circle with initials) -->
                    <Circle fx:id="avatarCircle" radius="28"
                            style="-fx-fill: #2563EB;"/>
                    <Label fx:id="avatarInitials" text="?"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"
                           StackPane.alignment="CENTER"/>
                    <!-- Photo (shown when available, overlaps circle) -->
                    <ImageView fx:id="profilePhoto" fitWidth="56" fitHeight="56"
                               preserveRatio="false" smooth="true" visible="false"
                               StackPane.alignment="CENTER">
                        <clip>
                            <Circle centerX="28" centerY="28" radius="28"/>
                        </clip>
                    </ImageView>
                </StackPane>

                <Label text="Akun Saya"
                       style="-fx-font-size: 10px; -fx-text-fill: #93C5FD; -fx-font-weight: bold; -fx-padding: 4 0 0 0;"/>
                <Label fx:id="userNameLabel"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white; -fx-wrap-text: true;"
                       maxWidth="178"/>
                <Label fx:id="userNimLabel" text=""
                       style="-fx-font-size: 11px; -fx-text-fill: #BAE6FD;"/>
                <Label fx:id="userRoleLabel"
                       style="-fx-font-size: 11px; -fx-text-fill: #93C5FD;"/>

                <!-- Edit Profile button -->
                <Button text="Edit Profil" onAction="#handleEditProfile"
                        style="-fx-background-color: #1D4ED8; -fx-text-fill: white; -fx-font-size: 11px;
                               -fx-background-radius: 5; -fx-padding: 4 12 4 12; -fx-cursor: hand;
                               -fx-border-color: #3B82F6; -fx-border-radius: 5; -fx-border-width: 1;"/>
            </VBox>

            <!-- Navigation -->
            <VBox spacing="0" style="-fx-padding: 10 0 0 0;">
                <Button text="  Dashboard"
                        style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-size: 13px;
                               -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16;
                               -fx-background-radius: 0; -fx-cursor: hand; -fx-max-width: Infinity;
                               -fx-pref-width: 210;"/>
            </VBox>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Logout -->
            <Button text="  Logout" onAction="#handleLogout"
                    style="-fx-background-color: #7F1D1D; -fx-text-fill: #FECACA; -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 16;
                           -fx-background-radius: 0; -fx-cursor: hand; -fx-max-width: Infinity;
                           -fx-pref-width: 210;"/>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox spacing="0" style="-fx-background-color: #F1F5F9;">

            <!-- Top bar -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding: 14 24 12 24; -fx-background-color: white;
                         -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
                <VBox spacing="2">
                    <Label text="Dashboard"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                    <Label text="Selamat datang! Kelola proyek kamu di sini."
                           style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="newProjectButton" text="+ Buat Proyek Baru"
                        onAction="#handleNewProject"
                        style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-size: 13px;
                               -fx-font-weight: bold; -fx-background-radius: 8px;
                               -fx-padding: 8 18 8 18; -fx-cursor: hand;"/>
            </HBox>

            <ScrollPane fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox spacing="14" style="-fx-padding: 16 24 20 24;">

                    <!-- Stat Cards Row -->
                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <!-- Total Proyek -->
                        <VBox spacing="4"
                              style="-fx-background-color: white; -fx-background-radius: 10;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);
                                     -fx-padding: 14 20 14 20; -fx-pref-width: 170; -fx-min-width: 140;">
                            <Label text="[ Proyek ]"
                                   style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                            <Label fx:id="statTotalProyek" text="0"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>
                            <Label text="Total Proyek"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
                        </VBox>

                        <!-- Task Overdue -->
                        <VBox spacing="4"
                              style="-fx-background-color: white; -fx-background-radius: 10;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);
                                     -fx-padding: 14 20 14 20; -fx-pref-width: 170; -fx-min-width: 140;">
                            <Label text="[ Terlambat ]"
                                   style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                            <Label fx:id="statOverdue" text="0"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #DC2626;"/>
                            <Label text="Task Overdue"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
                        </VBox>

                        <!-- Task Selesai -->
                        <VBox spacing="4"
                              style="-fx-background-color: white; -fx-background-radius: 10;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);
                                     -fx-padding: 14 20 14 20; -fx-pref-width: 170; -fx-min-width: 140;">
                            <Label text="[ Selesai ]"
                                   style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                            <Label fx:id="statSelesai" text="0"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
                            <Label text="Task Selesai"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
                        </VBox>
                    </HBox>

                    <!-- Section header + search -->
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Proyek Saya"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="searchField" promptText="Cari proyek..."
                                   onKeyReleased="#handleSearch"
                                   style="-fx-background-color: white; -fx-border-color: #D1D5DB;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-pref-height: 34; -fx-font-size: 13px;
                                          -fx-padding: 0 12 0 12; -fx-pref-width: 260;"/>
                    </HBox>

                    <!-- Status/Loading -->
                    <ProgressIndicator fx:id="loadingIndicator" prefWidth="36" prefHeight="36" visible="false"/>
                    <Label fx:id="statusLabel" style="-fx-text-fill: #DC2626; -fx-font-size: 13px;"/>

                    <!-- Project cards grid -->
                    <FlowPane fx:id="projectsPane" hgap="16" vgap="16"/>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>

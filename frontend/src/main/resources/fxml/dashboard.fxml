<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.taskforge.ui.controller.DashboardController"
            style="-fx-background-color: #F0F4FF;">

    <!-- Top header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #1E3A8A; -fx-padding: 12 20 12 20;">
            <Label text="TaskForge"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label fx:id="userNameLabel"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label fx:id="userRoleLabel"
                       style="-fx-font-size: 11px; -fx-text-fill: #93C5FD;"/>
            </VBox>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-font-size: 12px;
                           -fx-background-radius: 6px; -fx-padding: 6 14 6 14; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <VBox spacing="0">
            <!-- Sub-header -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding: 16 24 12 24; -fx-background-color: white;
                         -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">
                <Label text="Proyek Saya"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="newProjectButton" text="+ Buat Proyek Baru"
                        onAction="#handleNewProject"
                        style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-size: 13px;
                               -fx-font-weight: bold; -fx-background-radius: 6px;
                               -fx-padding: 8 16 8 16; -fx-cursor: hand;"/>
            </HBox>

            <!-- Project cards area -->
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox style="-fx-padding: 20 24 20 24;" spacing="12">
                    <ProgressIndicator fx:id="loadingIndicator" prefWidth="40" prefHeight="40"/>
                    <Label fx:id="statusLabel" style="-fx-text-fill: #DC2626; -fx-font-size: 13px;"/>
                    <FlowPane fx:id="projectsPane" hgap="16" vgap="16"/>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.taskforge.ui.controller.DashboardController"
            style="-fx-background-color: #F8FAFC;">

    <!-- ==================== SIDEBAR ==================== -->
    <left>
        <VBox minWidth="220" prefWidth="220" maxWidth="220" spacing="0"
              style="-fx-background-color: #0F172A;">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 16 16 16 16;
                         -fx-border-color: #1E293B; -fx-border-width: 0 0 1 0;">
                <ImageView fitWidth="34" fitHeight="34" preserveRatio="true" smooth="true">
                    <image><Image url="@/images/taskforge-icon-48.png"/></image>
                </ImageView>
                <HBox spacing="0" alignment="CENTER_LEFT">
                    <Label text="Task"
                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Forge"
                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #6366F1;"/>
                </HBox>
            </HBox>

            <!-- User Profile Section -->
            <VBox spacing="6"
                  style="-fx-padding: 16 16 16 16;
                         -fx-border-color: #1E293B; -fx-border-width: 0 0 1 0;">

                <StackPane prefWidth="56" prefHeight="56">
                    <Rectangle width="56" height="56" arcWidth="12" arcHeight="12"
                               style="-fx-fill: #0F172A;"/>
                    <Label fx:id="avatarInitials" text="?"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"
                           StackPane.alignment="CENTER"/>
                </StackPane>

                <Label text="AKUN SAYA"
                       style="-fx-font-size: 9px; -fx-font-weight: bold;
                              -fx-text-fill: #475569; -fx-padding: 6 0 0 0;"/>
                <Label fx:id="userNameLabel"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;
                              -fx-text-fill: #F1F5F9; -fx-wrap-text: true;"
                       maxWidth="188"/>
                <Label fx:id="userNimLabel" text=""
                       style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>

                <!-- Role badge -->
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="userRoleLabel"
                           style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #A5B4FC;
                                  -fx-background-color: #1E1B4B; -fx-background-radius: 20;
                                  -fx-padding: 3 10 3 10;"/>
                </HBox>

            </VBox>

            <!-- Navigation -->
            <VBox spacing="0">
                <Label text="WORKSPACE"
                       style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #475569;
                              -fx-padding: 16 0 6 20;"/>
                <Button text="  Dashboard"
                        styleClass="sidebar-nav-btn-active"
                        style="-fx-max-width: Infinity; -fx-pref-width: 220;"/>
                <Button text="  Proyek" onAction="#handleProyek"
                        styleClass="sidebar-nav-btn"
                        style="-fx-max-width: Infinity; -fx-pref-width: 220;"/>
                <Button text="  Notifikasi" onAction="#handleNotifikasi"
                        styleClass="sidebar-nav-btn"
                        style="-fx-max-width: Infinity; -fx-pref-width: 220;"/>
                <Button text="  Profil" onAction="#handleProfil"
                        styleClass="sidebar-nav-btn"
                        style="-fx-max-width: Infinity; -fx-pref-width: 220;"/>
            </VBox>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Logout -->
            <VBox style="-fx-border-color: #1E293B; -fx-border-width: 1 0 0 0;">
                <Button text="  Keluar" onAction="#handleLogout"
                        style="-fx-background-color: transparent; -fx-text-fill: #F87171;
                               -fx-font-size: 13px; -fx-alignment: CENTER_LEFT;
                               -fx-padding: 13 16 13 20; -fx-background-radius: 0;
                               -fx-cursor: hand; -fx-max-width: Infinity; -fx-pref-width: 220;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ==================== MAIN CONTENT ==================== -->
    <center>
        <VBox spacing="0" style="-fx-background-color: #F8FAFC;">

            <!-- Top Bar -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding: 16 28 14 28; -fx-background-color: white;
                         -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;
                         -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.04), 4, 0, 0, 2);">
                <VBox spacing="2">
                    <Label text="Dashboard"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                    <Label text="Kelola semua proyek kelompok kamu di sini"
                           style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <ScrollPane fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox spacing="20" style="-fx-padding: 24 28 28 28;">

                    <!-- Stat Cards -->
                    <HBox spacing="16" alignment="CENTER_LEFT">

                        <!-- Total Proyek -->
                        <VBox spacing="0"
                              style="-fx-background-color: white; -fx-background-radius: 14;
                                     -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.07), 10, 0, 0, 3);
                                     -fx-pref-width: 185; -fx-min-width: 155;
                                     -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-border-width: 1;">
                            <Region style="-fx-background-color: #4F46E5;
                                          -fx-background-radius: 14 14 0 0;
                                          -fx-min-height: 4; -fx-max-height: 4;"/>
                            <VBox spacing="4" style="-fx-padding: 16 20 18 20;">
                                <Label text="TOTAL PROYEK"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                                              -fx-text-fill: #94A3B8;"/>
                                <Label fx:id="statTotalProyek" text="0"
                                       style="-fx-font-size: 32px; -fx-font-weight: bold;
                                              -fx-text-fill: #4F46E5;"/>
                                <Label text="Proyek Aktif"
                                       style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
                            </VBox>
                        </VBox>

                        <!-- Task Overdue -->
                        <VBox spacing="0"
                              style="-fx-background-color: white; -fx-background-radius: 14;
                                     -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.07), 10, 0, 0, 3);
                                     -fx-pref-width: 185; -fx-min-width: 155;
                                     -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-border-width: 1;">
                            <Region style="-fx-background-color: #EF4444;
                                          -fx-background-radius: 14 14 0 0;
                                          -fx-min-height: 4; -fx-max-height: 4;"/>
                            <VBox spacing="4" style="-fx-padding: 16 20 18 20;">
                                <Label text="TERLAMBAT"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                                              -fx-text-fill: #94A3B8;"/>
                                <Label fx:id="statOverdue" text="0"
                                       style="-fx-font-size: 32px; -fx-font-weight: bold;
                                              -fx-text-fill: #EF4444;"/>
                                <Label text="Task Overdue"
                                       style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
                            </VBox>
                        </VBox>

                        <!-- Task Selesai -->
                        <VBox spacing="0"
                              style="-fx-background-color: white; -fx-background-radius: 14;
                                     -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.07), 10, 0, 0, 3);
                                     -fx-pref-width: 185; -fx-min-width: 155;
                                     -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-border-width: 1;">
                            <Region style="-fx-background-color: #10B981;
                                          -fx-background-radius: 14 14 0 0;
                                          -fx-min-height: 4; -fx-max-height: 4;"/>
                            <VBox spacing="4" style="-fx-padding: 16 20 18 20;">
                                <Label text="SELESAI"
                                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                                              -fx-text-fill: #94A3B8;"/>
                                <Label fx:id="statSelesai" text="0"
                                       style="-fx-font-size: 32px; -fx-font-weight: bold;
                                              -fx-text-fill: #10B981;"/>
                                <Label text="Task Selesai"
                                       style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
                            </VBox>
                        </VBox>
                    </HBox>

                    <!-- Section Header -->
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          style="-fx-padding: 4 0 0 0;">
                        <VBox spacing="2">
                            <Label text="Proyek Saya"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold;
                                          -fx-text-fill: #1E293B;"/>
                            <Label text="Klik proyek untuk melihat detail"
                                   style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="searchField" promptText="Cari proyek..."
                                   onKeyReleased="#handleSearch"
                                   style="-fx-background-color: white; -fx-border-color: #E2E8F0;
                                          -fx-border-radius: 10; -fx-background-radius: 10;
                                          -fx-pref-height: 36; -fx-font-size: 13px;
                                          -fx-padding: 0 14 0 14; -fx-pref-width: 260;"/>
                    </HBox>

                    <!-- Loading / Status -->
                    <ProgressIndicator fx:id="loadingIndicator"
                                       prefWidth="36" prefHeight="36" visible="false"/>
                    <Label fx:id="statusLabel"
                           style="-fx-text-fill: #EF4444; -fx-font-size: 13px;"/>

                    <!-- Project Cards Grid -->
                    <FlowPane fx:id="projectsPane" hgap="18" vgap="18"/>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
